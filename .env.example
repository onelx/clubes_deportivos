# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration
# Get these from your Stripe dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Connect (for club payouts)
# Create a Connect platform: https://dashboard.stripe.com/settings/connect
STRIPE_CONNECT_CLIENT_ID=ca_your-connect-client-id-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ClubStore Platform

# Default Platform Commission (percentage)
DEFAULT_PLATFORM_COMMISSION=15

# Email Configuration (optional - for order notifications)
# Using Resend: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=noreply@your-domain.com

# File Upload Configuration
# Maximum file size for product images (in MB)
MAX_FILE_SIZE=5

# Shipping Configuration
# Default shipping cost (can be overridden per club)
DEFAULT_SHIPPING_COST=500
