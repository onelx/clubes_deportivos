# ===========================================
# SUPABASE - Base de datos y autenticación
# ===========================================
# URL de tu proyecto Supabase (encontrarlo en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (segura para el frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio de Supabase (SOLO para el backend, nunca exponer)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# STRIPE - Procesamiento de pagos
# ===========================================
# Clave pública de Stripe (para el frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta de Stripe (SOLO backend)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret de Stripe (para validar webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# APP CONFIG
# ===========================================
# URL base de la aplicación (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comisión por defecto de la plataforma (porcentaje)
DEFAULT_PLATFORM_COMMISSION=15

# ===========================================
# OPTIONAL - Analytics y monitoreo
# ===========================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://...@sentry.io/...
