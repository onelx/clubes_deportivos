# ===========================================
# Supabase Configuration
# ===========================================
# URL de tu proyecto Supabase (encontrar en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave pública anon (encontrar en Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave de servicio (solo para uso servidor, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ID del proyecto (para generar tipos)
SUPABASE_PROJECT_ID=your-project-id

# ===========================================
# Stripe Configuration
# ===========================================
# Clave pública de Stripe (empieza con pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Clave secreta de Stripe (empieza con sk_)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Secreto del webhook de Stripe (empieza con whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# Application Configuration
# ===========================================
# URL base de la aplicación (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Entorno de la aplicación
NODE_ENV=development

# ===========================================
# Email Configuration (opcional, para notificaciones)
# ===========================================
# RESEND_API_KEY=re_your-resend-api-key
# EMAIL_FROM=noreply@tudominio.com

# ===========================================
# Storage Configuration
# ===========================================
# Bucket de Supabase para imágenes de productos
NEXT_PUBLIC_STORAGE_BUCKET=productos
