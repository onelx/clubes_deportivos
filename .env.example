# ===========================================
# SUPABASE - Base de datos y autenticación
# ===========================================
# URL del proyecto Supabase (encontrar en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio de Supabase (SOLO para servidor, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# STRIPE - Procesamiento de pagos
# ===========================================
# Clave pública de Stripe (segura para el cliente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta de Stripe (SOLO para servidor)
STRIPE_SECRET_KEY=sk_test_...

# Secreto del webhook de Stripe (para verificar eventos)
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# APLICACIÓN
# ===========================================
# URL base de la aplicación (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL base para tiendas de clubes (subdominio o path-based)
NEXT_PUBLIC_STORE_URL=http://localhost:3000/tienda

# Comisión por defecto de la plataforma (porcentaje)
DEFAULT_PLATFORM_COMMISSION=15

# ===========================================
# ENVÍO Y LOGÍSTICA (Opcional)
# ===========================================
# API de envíos si se integra con un proveedor
# SHIPPING_API_KEY=
# SHIPPING_API_URL=

# ===========================================
# EMAILS (Opcional - Supabase tiene built-in)
# ===========================================
# Si usas un servicio externo como Resend
# RESEND_API_KEY=re_...
