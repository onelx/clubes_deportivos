# ============================================
# SUPABASE - Base de datos y autenticación
# ============================================
# URL de tu proyecto Supabase (encontrar en Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública de Supabase (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Clave de servicio de Supabase (SOLO para servidor, Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ============================================
# STRIPE - Procesamiento de pagos
# ============================================
# Clave pública de Stripe (Dashboard > Developers > API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Clave secreta de Stripe (SOLO servidor)
STRIPE_SECRET_KEY=sk_test_xxx

# Secret del webhook de Stripe (Developers > Webhooks > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================
# APLICACIÓN
# ============================================
# URL base de la aplicación (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre de la plataforma
NEXT_PUBLIC_PLATFORM_NAME=ClubStore

# Comisión por defecto de la plataforma (porcentaje)
DEFAULT_PLATFORM_COMMISSION=15

# ============================================
# EMAILS (opcional - para notificaciones)
# ============================================
# RESEND_API_KEY=re_xxx

# ============================================
# STORAGE (para imágenes de productos)
# ============================================
# Bucket de Supabase Storage para imágenes
SUPABASE_STORAGE_BUCKET=productos
