# ===========================================
# SUPABASE - Configuración de base de datos
# ===========================================
# URL de tu proyecto Supabase (encontrar en Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública de Supabase (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio de Supabase (SOLO para servidor, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# STRIPE - Procesamiento de pagos
# ===========================================
# Clave pública de Stripe (para el cliente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta de Stripe (SOLO servidor)
STRIPE_SECRET_KEY=sk_test_...

# Secreto del webhook de Stripe (para verificar eventos)
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# APP - Configuración general
# ===========================================
# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre de la plataforma
NEXT_PUBLIC_PLATFORM_NAME=ClubStore

# Porcentaje de comisión por defecto para nuevos clubes (ej: 15 = 15%)
DEFAULT_PLATFORM_COMMISSION=15

# ===========================================
# EMAIL (opcional - para notificaciones)
# ===========================================
# RESEND_API_KEY=re_...

# ===========================================
# STORAGE
# ===========================================
# Bucket de Supabase para imágenes de productos
SUPABASE_STORAGE_BUCKET=productos
