# Supabase Configuration
# Obtené estos valores desde tu proyecto en https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Stripe Configuration
# Claves de Stripe desde https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_tu_publishable_key
STRIPE_SECRET_KEY=sk_test_tu_secret_key

# Stripe Webhook Secret
# Generado al crear un webhook endpoint en https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret

# URL Base de la Aplicación
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Connect
# ID de cuenta de Stripe Connect de la plataforma
STRIPE_PLATFORM_ACCOUNT_ID=acct_tu_platform_account_id

# Configuración de Producción
# Porcentaje de comisión que cobra la plataforma (ej: 0.15 para 15%)
PLATFORM_COMMISSION_RATE=0.15

# Costo de Envío Base
SHIPPING_BASE_COST=500
